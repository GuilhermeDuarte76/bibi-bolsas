# Configuracao da Bibi Bolsas Front-end
# Copie para `.env` e ajuste quando o backend .NET estiver pronto.

# URL base da API .NET (sem barra no final). Ex.: https://api.bibibolsas.com.br
VITE_API_URL=

# Use dados mockados? `true` (padrao, sem backend) ou `false` (integra a API real).
VITE_USE_MOCK=true
